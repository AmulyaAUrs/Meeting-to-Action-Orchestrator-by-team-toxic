# Copy this file to ".env" and set ONE provider key. neuro-san automatically
# selects whichever provider's key is present (see config/llm_config.hocon).

# Anthropic Claude (default provider) — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI (fallback) — https://platform.openai.com/api-keys
# OPENAI_API_KEY=

# Google Gemini (fallback) — https://ai.google.dev/gemini-api/docs/api-key
# GEMINI_API_KEY=

# Mistral (fallback; preconfigured hackathon option) — https://admin.mistral.ai/
# MISTRAL_API_KEY=
